generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ENGINEER
  HEALTHCARE_PROFESSIONAL
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String
  role      UserRole
  createdAt DateTime @default(now())

  posts     Post[]
}

enum PostStatus {
  DRAFT
  ACTIVE
  MEETING_SCHEDULED
  PARTNER_FOUND
  EXPIRED
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  status      PostStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())

  authorId    Int
  author      User       @relation(fields: [authorId], references: [id])
}